# Python
.venv/
__pycache__/
*.pyc
dist/
build/
*.egg-info/

# Results
results/runs/
results/baselines/
results/trainable_baselines/
results/trainable_fixtures/
!results/README.md
artifacts/
*.csv

# Device profiles: ignore raw traces but keep analysis outputs and fixtures
results/device_profiles/**/
!results/device_profiles/_fixtures/
!results/device_profiles/_fixtures/**
!results/device_profiles/analysis/
!results/device_profiles/analysis/**
*.trace

# Model artifacts (checkpoints are large; only commit configs and code)
*.pt
*.pth
*.mlpackage
*.mlmodel

# Claude Code local settings
.claude/settings.local.json

# Xcode user-specific state (per-user editor layout, scheme order, etc.)
xcuserdata/
*.xcuserstate

# Data policy: NEVER commit raw screenshots
data/raw/
data/images/
*.png
*.jpg
*.jpeg
*.heic
*.webp
